import pandas as pd
import matplotlib.pyplot as plt
from sklearn.model_selection import train_test_split
from sklearn.tree import DecisionTreeClassifier, plot_tree
from sklearn.metrics import accuracy_score, confusion_matrix

df = pd.read_excel("decision_tree_dataset.xlsx")
print(df.head()) 
X = df[['Hours', 'Attendance', 'Assignment']]
y = df['Output']
X_train, X_test, y_train, y_test = train_test_split(
    X, y, test_size=0.2, random_state=0
)

model = DecisionTreeClassifier(max_depth=3)  
model.fit(X_train, y_train)

y_pred = model.predict(X_test)

print("Accuracy:", accuracy_score(y_test, y_pred))

# Confusion Matrix
print("Confusion Matrix:\n", confusion_matrix(y_test, y_pred))

# New Input
new_data = pd.DataFrame({
    'Hours': [4, 7],
    'Attendance': [70, 85],
    'Assignment': [3, 4]
})

prediction = model.predict(new_data)

print("New Input:\n", new_data)
print("Prediction (0=Fail, 1=Pass):", prediction)

# Graph 
plt.figure(figsize=(12,6))

plot_tree(
    model,
    feature_names=['Hours', 'Attendance', 'Assignment'],
    class_names=['Fail','Pass'],
    filled=True,
    rounded=True,
    fontsize=10
)

plt.title("Decision Tree (Clear View)")
plt.show()
