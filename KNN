import pandas as pd
import numpy as np
import matplotlib.pyplot as plt
from sklearn.model_selection import train_test_split
from sklearn.neighbors import KNeighborsRegressor
from sklearn.metrics import r2_score
from sklearn.preprocessing import StandardScaler

# Load dataset
df = pd.read_excel("KNN_data.xlsx")
df.columns = df.columns.str.strip()
print("First 5 rows:\n", df.head())

# Features and Target
X = df[['Hours']].values
y = df['Marks'].values

#  Feature Scaling
scaler = StandardScaler()
X_scaled = scaler.fit_transform(X)

# Train-Test Split
X_train, X_test, y_train, y_test = train_test_split(
    X_scaled, y, test_size=0.2, random_state=42
)

# KNN Regression
k = 3
knn_model = KNeighborsRegressor(n_neighbors=k)
knn_model.fit(X_train, y_train)

# Test prediction
y_pred = knn_model.predict(X_test)
accuracy = r2_score(y_test, y_pred)
print(f"Test Accuracy (R²): {accuracy:.4f}")

# New student prediction
new_student = np.array([[5]])
new_student_scaled = scaler.transform(new_student)
prediction = knn_model.predict(new_student_scaled)
print(f"Predicted Marks for 5 hours study: {prediction[0]:.2f}")

# Plot Actual (blue) + Predicted points (green dots)
plt.scatter(df['Hours'], df['Marks'], color='blue', label='Actual Marks')

# Predicted points for all hours in dataset
X_scaled_all = scaler.transform(df[['Hours']].values)
y_pred_all = knn_model.predict(X_scaled_all)
plt.scatter(df['Hours'], y_pred_all, color='green', label='KNN Predicted Marks')

plt.xlabel('Hours')
plt.ylabel('Marks')
plt.title(f'KNN Regression Predictions (k={k})')
plt.legend()
plt.show()
